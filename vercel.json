{
  "rewrites": [
    {
      "source": "/docs/:path*",
      "destination": "https://docs.usewisp.dev/:path*"
    },
    {
      "source": "/docs",
      "destination": "https://docs.usewisp.dev"
    },
    {
      "source": "/blog/:path*",
      "destination": "https://blog.usewisp.dev/:path*"
    },
    {
      "source": "/blog",
      "destination": "https://blog.usewisp.dev"
    }
  ]
}
